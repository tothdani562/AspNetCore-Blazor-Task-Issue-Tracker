    {
      "name": "Projects",
      "item": [
        {
          "name": "4. Create Project",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.environment.set('project_name', `Iteration 5 Project ${Date.now()}`);",
                  "pm.environment.set('project_description', 'Projects backend iteration 5 test project');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "pm.test('Project creation is successful', function () {",
                  "  pm.expect(body).to.have.property('success', true);",
                  "  pm.expect(body.data).to.be.an('object');",
                  "});",
                  "pm.test('Project payload contains owner and id', function () {",
                  "  pm.expect(body.data.id).to.be.a('string').and.not.empty;",
                  "  pm.expect(body.data.owner.id).to.equal(pm.environment.get('owner_user_id'));",
                  "  pm.expect(body.data.name).to.equal(pm.environment.get('project_name'));",
                  "});",
                  "pm.environment.set('project_id', body.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{owner_access_token}}",
                  "type": "string"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{project_name}}\",\n  \"description\": \"{{project_description}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/projects",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "projects"
              ]
            }
          }
