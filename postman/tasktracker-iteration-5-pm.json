{
  "info": {
    "name": "TaskTracker Iteration 5 - Projects Backend & Authorization",
    "description": "Project CRUD and membership authorization tests (Iteration 5).\nFlow: create users -> create project -> share project -> verify owner/member/outsider access -> cleanup.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
