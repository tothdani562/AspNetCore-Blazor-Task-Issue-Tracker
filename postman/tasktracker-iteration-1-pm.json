            "url": {
              "raw": "{{baseUrl}}/",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                ""
              ]
            }
          },
          "status": "OK",
          "code": 200,
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json; charset=utf-8"
            },
            {
              "key": "Content-Length",
              "value": "21"
            }
          ],
          "body": "{\"success\":true,\"data\":{}}"
        }
      ]
    },
    {
      "name": "Database Health Check - Connectivity Test",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Verify API responds with 200 for successful database connection",
              "pm.test('Status code is 200 - Database connected', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "// Parse response",
              "const responseJson = pm.response.json();",
              "",
              "// Validate response structure",
              "pm.test('Response has success property', function () {",
              "  pm.expect(responseJson).to.have.property('success');",
              "  pm.expect(responseJson.success).to.equal(true);",
              "});",
              "",
              "// Validate data contains database status",
              "pm.test('Response contains database status', function () {",
              "  pm.expect(responseJson.data).to.have.property('status');",
              "  pm.expect(responseJson.data.status).to.equal('database_connected');",
              "});",
              "",
              "// Validate User table query result",
              "pm.test('Response contains userCount from database query', function () {",
              "  pm.expect(responseJson.data).to.have.property('userCount');",
              "  pm.expect(responseJson.data.userCount).to.be.a('number');",
              "});",
              "",
              "// Validate response contains timestamp",
              "pm.test('Response contains timestamp', function () {",
              "  pm.expect(responseJson.data).to.have.property('timestamp');",
              "});",
              "",
              "// Response time benchmark",
              "pm.test('Response time acceptable for database query (<2000ms)', function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "// Store successful response",
              "pm.environment.set('lastDbHealthCheck', JSON.stringify(responseJson.data));"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Accept",
            "value": "application/json",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/health/db",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "health",
            "db"
          ]
        },
        "description": "Database connectivity test endpoint - valós adatbázis query futtatásával.\n\nEz a végpont:\n- Teszteli a PostgreSQL adatbázis csatlakozást\n- Valós User tábla lekérdezést végez (COUNT query)\n- EF Core DbContext működésének igazolása\n\nExpected response format:\n```json\n{\n  \"success\": true,\n  \"data\": {\n    \"status\": \"database_connected\",\n    \"timestamp\": \"2026-03-31T12:00:00.000Z\",\n    \"userCount\": 0,\n    \"version\": \"0.1.0\"\n  }\n}\n```\n\nHiba esetén (503 Service Unavailable):\n```json\n{\n  \"success\": false,\n  \"data\": {\n    \"status\": \"database_unavailable\",\n    \"timestamp\": \"2026-03-31T12:00:00.000Z\",\n    \"error\": \"Exception message\"\n  }\n}\n```"
      },
      "response": [
        {
          "name": "Success - Database Connected",
          "originalRequest": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/health/db",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health",
                "db"
              ]
            }
          },
          "status": "OK",
          "code": 200,
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json; charset=utf-8"
            }
          ],
          "body": "{\"success\":true,\"data\":{\"status\":\"database_connected\",\"timestamp\":\"2026-03-31T12:00:00.000Z\",\"userCount\":0,\"version\":\"0.1.0\"}}"
        },
        {
          "name": "Error - Database Unavailable",
          "originalRequest": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/health/db",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health",
                "db"
              ]
            }
          },
          "status": "Service Unavailable",
          "code": 503,
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json; charset=utf-8"
            }
          ],
          "body": "{\"success\":false,\"data\":{\"status\":\"database_unavailable\",\"timestamp\":\"2026-03-31T12:00:00.000Z\",\"error\":\"Connection refused\"}}"
        }
      ]
    }
  ],
