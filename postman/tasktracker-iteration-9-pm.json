    {
      "name": "Advanced Query Tests",
      "item": [
        {
          "name": "8. Combined Filters + CreatedAt Sort",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Combined filters return the two owner TODO tasks in createdAt order', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.success).to.equal(true);",
                  "  pm.expect(body.data.totalCount).to.equal(2);",
                  "  pm.expect(body.data.items).to.have.lengthOf(2);",
                  "  pm.expect(body.data.items[0].title).to.equal(pm.environment.get('task_beta_title'));",
                  "  pm.expect(body.data.items[1].title).to.equal(pm.environment.get('task_alpha_title'));",
                  "});"
