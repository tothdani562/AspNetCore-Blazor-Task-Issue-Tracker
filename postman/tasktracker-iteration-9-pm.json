      "name": "Auth Setup",
      "item": [
        {
          "name": "1. Register Owner",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const uniqueId = Date.now();",
                  "pm.environment.set('owner_email', `iteration9.owner.${uniqueId}@example.com`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Owner auth response is stored', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.success).to.equal(true);",
                  "  pm.expect(body.data.accessToken).to.be.a('string').and.not.empty;",
                  "  pm.expect(body.data.user.id).to.be.a('string').and.not.empty;",
                  "  pm.environment.set('owner_access_token', body.data.accessToken);",
                  "  pm.environment.set('owner_user_id', body.data.user.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
