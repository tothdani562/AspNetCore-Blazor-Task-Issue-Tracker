{
  "info": {
    "name": "TaskTracker Iteration 11 - Comments Backend",
    "description": "End-to-end API test flow for Iteration 11 comments backend. Covers setup, comment CRUD, pagination, and authorization rules (author/project owner/member/outsider).",
