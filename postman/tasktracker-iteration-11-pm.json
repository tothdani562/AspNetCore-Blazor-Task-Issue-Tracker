  "item": [
    {
      "name": "Setup",
      "item": [
        {
          "name": "1. Register Owner",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const uniqueId = Date.now();",
                  "pm.environment.set('owner_email', `iteration11.owner.${uniqueId}@example.com`);",
                  "pm.environment.set('owner_fullname', 'Iteration 11 Owner');",
                  "pm.environment.set('owner_password', 'Passw0rd!123');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Owner register response shape is valid', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.success).to.equal(true);",
                  "  pm.expect(body.data.accessToken).to.be.a('string').and.not.empty;",
                  "  pm.expect(body.data.refreshToken).to.be.a('string').and.not.empty;",
                  "  pm.expect(body.data.user.id).to.be.a('string').and.not.empty;",
                  "  pm.environment.set('owner_access_token', body.data.accessToken);",
                  "  pm.environment.set('owner_refresh_token', body.data.refreshToken);",
                  "  pm.environment.set('owner_user_id', body.data.user.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{owner_email}}\",\n  \"fullName\": \"{{owner_fullname}}\",\n  \"password\": \"{{owner_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          }
        },
