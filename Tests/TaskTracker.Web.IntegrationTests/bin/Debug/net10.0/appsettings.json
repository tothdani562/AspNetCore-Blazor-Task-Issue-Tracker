{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=tasktracker_db;Username=tasktracker;Password=change_me;"
  },
  "Jwt": {
    "Issuer": "TaskTracker.Web",
    "Audience": "TaskTracker.Client",
    "SigningKey": "",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "Cors": {
    "AllowedOrigins": [],
    "AllowCredentials": false
  },
  "RateLimiting": {
    "Auth": {
      "PermitLimit": 8,
      "WindowSeconds": 60
    }
  },
  "Database": {
    "EnableRetryOnFailure": true,
    "MaxRetryCount": 5,
    "MaxRetryDelaySeconds": 10,
    "CommandTimeoutSeconds": 30,
    "FailOnStartupError": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Information"
    }
  },
  "AllowedHosts": "*"
}
