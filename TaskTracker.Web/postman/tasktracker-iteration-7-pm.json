        {
          "name": "8. List Tasks with Filters + Pagination",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.test('Filtered paged result is valid', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.success).to.equal(true);",
                  "  pm.expect(body.data.items).to.be.an('array');",
                  "  pm.expect(body.data.page).to.equal(1);",
                  "  pm.expect(body.data.limit).to.equal(1);",
                  "  pm.expect(body.data.totalCount).to.be.greaterThan(0);",
                  "  pm.expect(body.data.totalPages).to.be.greaterThan(0);",
                  "  pm.expect(body.data.items[0].status).to.equal(0);",
                  "  pm.expect(body.data.items[0].priority).to.equal(2);",
                  "  pm.expect(body.data.items[0].assignedUserId).to.equal(pm.environment.get('member_user_id'));",
                  "});"
                ]
              }
            }
          ],
