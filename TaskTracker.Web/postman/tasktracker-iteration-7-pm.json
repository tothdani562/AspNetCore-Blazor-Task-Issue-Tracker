    {
      "name": "Tasks CRUD + Query",
      "item": [
        {
          "name": "6. Create Task 1 as Member",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const dueDate = new Date(Date.now() + 2 * 24 * 60 * 60 * 1000).toISOString();",
                  "pm.environment.set('task_title', `Iteration 7 Task ${Date.now()}`);",
                  "pm.environment.set('task_description', 'Task created in iteration 7 collection');",
                  "pm.environment.set('task_due_date', dueDate);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "pm.test('Task 1 is created and id is stored', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.success).to.equal(true);",
                  "  pm.expect(body.data.id).to.be.a('string').and.not.empty;",
                  "  pm.expect(body.data.title).to.equal(pm.environment.get('task_title'));",
                  "  pm.expect(body.data.status).to.equal(0);",
                  "  pm.expect(body.data.priority).to.equal(2);",
                  "  pm.environment.set('task_id', body.data.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{member_access_token}}",
                  "type": "string"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"{{task_title}}\",\n  \"description\": \"{{task_description}}\",\n  \"status\": 0,\n  \"priority\": 2,\n  \"assignedUserId\": \"{{member_user_id}}\",\n  \"dueDate\": \"{{task_due_date}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/projects/{{project_id}}/tasks",
              "host": [
