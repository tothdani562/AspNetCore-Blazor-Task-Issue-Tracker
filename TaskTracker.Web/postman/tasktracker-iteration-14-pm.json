{
  "info": {
    "name": "TaskTracker Iteration 14 - Security Hardening",
    "description": "Security hardening test flow for Iteration 14. Covers input validation edge cases, unified auth error responses, CORS behavior, and auth endpoint rate limiting.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "item": [
    {
      "name": "Setup",
      "item": [
        {
          "name": "1. Register Security User",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const uniqueId = Date.now();",
                  "pm.environment.set('iteration14_email', `iteration14.security.${uniqueId}@example.com`);",
                  "pm.environment.set('iteration14_fullname', 'Iteration 14 Security User');",
                  "pm.environment.set('iteration14_password', 'StrongPass123');",
                  "pm.environment.set('auth_flood_counter', '0');",
                  "pm.environment.set('auth_rate_limited', 'false');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Register response contains auth payload', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.success).to.equal(true);",
                  "  pm.expect(body.data.accessToken).to.be.a('string').and.not.empty;",
                  "  pm.expect(body.data.refreshToken).to.be.a('string').and.not.empty;",
                  "  pm.expect(body.data.user.id).to.be.a('string').and.not.empty;",
                  "  pm.environment.set('iteration14_access_token', body.data.accessToken);",
                  "  pm.environment.set('iteration14_refresh_token', body.data.refreshToken);",
                  "  pm.environment.set('iteration14_user_id', body.data.user.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{iteration14_email}}\",\n  \"fullName\": \"{{iteration14_fullname}}\",\n  \"password\": \"{{iteration14_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "2. Login With Registered User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Login returns new tokens', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.success).to.equal(true);",
                  "  pm.expect(body.data.accessToken).to.be.a('string').and.not.empty;",
                  "  pm.expect(body.data.refreshToken).to.be.a('string').and.not.empty;",
                  "  pm.environment.set('iteration14_access_token', body.data.accessToken);",
                  "  pm.environment.set('iteration14_refresh_token', body.data.refreshToken);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{iteration14_email}}\",\n  \"password\": \"{{iteration14_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Security Validations",
      "item": [
        {
          "name": "3. /auth/me With Valid Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Me endpoint returns expected user', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.success).to.equal(true);",
                  "  pm.expect(body.data.id).to.equal(pm.environment.get('iteration14_user_id'));",
                  "  pm.expect(body.data.email).to.equal(pm.environment.get('iteration14_email'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{iteration14_access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            }
          }
        },
        {
          "name": "4. /auth/me Without Token Returns Unified 401",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 401', function () {",
                  "  pm.response.to.have.status(401);",
                  "});",
                  "",
                  "pm.test('Unified error response shape is present', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.success).to.equal(false);",
                  "  pm.expect(body.statusCode).to.equal(401);",
                  "  pm.expect(body.message).to.be.a('string').and.not.empty;",
                  "  pm.expect(body.path).to.equal('/auth/me');",
                  "  pm.expect(body.timestamp).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            }
          }
        },
        {
          "name": "5. /auth/me With Invalid Token Returns 401",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 401', function () {",
                  "  pm.response.to.have.status(401);",
                  "});",
                  "",
                  "pm.test('Invalid token returns unified 401 response', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.success).to.equal(false);",
                  "  pm.expect(body.statusCode).to.equal(401);",
                  "  pm.expect(body.path).to.equal('/auth/me');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer invalid.jwt.token"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            }
          }
        },
        {
          "name": "6. Register Rejects Weak Password",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const uniqueId = Date.now() + 10;",
                  "pm.environment.set('weak_email', `iteration14.weak.${uniqueId}@example.com`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Weak password validation returns error response', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.success).to.equal(false);",
                  "  pm.expect(body.statusCode).to.equal(400);",
                  "  pm.expect(body.message).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{weak_email}}\",\n  \"fullName\": \"Weak Password User\",\n  \"password\": \"weakpass\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "7. Register Rejects Whitespace FullName",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const uniqueId = Date.now() + 20;",
                  "pm.environment.set('whitespace_email', `iteration14.whitespace.${uniqueId}@example.com`);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Whitespace validation returns error response', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.success).to.equal(false);",
                  "  pm.expect(body.statusCode).to.equal(400);",
                  "  pm.expect(body.message).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{whitespace_email}}\",\n  \"fullName\": \"   \",\n  \"password\": \"StrongPass123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          }
        },
        {
          "name": "8. Refresh Rejects Whitespace Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 400', function () {",
                  "  pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Refresh token validation returns error response', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.success).to.equal(false);",
                  "  pm.expect(body.statusCode).to.equal(400);",
                  "  pm.expect(body.message).to.be.a('string').and.not.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"   \"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "refresh"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "CORS",
      "item": [
        {
          "name": "9. CORS Preflight /auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Preflight returns 200 or 204', function () {",
                  "  pm.expect([200, 204]).to.include(pm.response.code);",
                  "});",
                  "",
                  "pm.test('CORS allow-origin header matches allowed origin', function () {",
                  "  pm.expect(pm.response.headers.get('Access-Control-Allow-Origin')).to.equal(pm.environment.get('allowed_origin'));",
                  "});",
                  "",
                  "pm.test('CORS allow-methods contains POST', function () {",
                  "  const allowMethods = pm.response.headers.get('Access-Control-Allow-Methods') || '';",
                  "  pm.expect(allowMethods.toUpperCase()).to.include('POST');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "OPTIONS",
            "header": [
              {
                "key": "Origin",
                "value": "{{allowed_origin}}"
              },
              {
                "key": "Access-Control-Request-Method",
                "value": "POST"
              },
              {
                "key": "Access-Control-Request-Headers",
                "value": "content-type"
              }
            ],
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "10. CORS Actual Login Request",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('CORS allow-origin is returned for actual request', function () {",
                  "  pm.expect(pm.response.headers.get('Access-Control-Allow-Origin')).to.equal(pm.environment.get('allowed_origin'));",
                  "});",
                  "",
                  "pm.test('Response returns tokens', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.success).to.equal(true);",
                  "  pm.expect(body.data.accessToken).to.be.a('string').and.not.empty;",
                  "  pm.environment.set('iteration14_access_token', body.data.accessToken);",
                  "  pm.environment.set('iteration14_refresh_token', body.data.refreshToken);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Origin",
                "value": "{{allowed_origin}}"
              },
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{iteration14_email}}\",\n  \"password\": \"{{iteration14_password}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Rate Limiting",
      "item": [
        {
          "name": "11. Auth Rate Limit Probe",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const current = Number(pm.environment.get('auth_flood_counter') || '0') + 1;",
                  "pm.environment.set('auth_flood_counter', String(current));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const current = Number(pm.environment.get('auth_flood_counter') || '0');",
                  "const maxAttempts = Number(pm.environment.get('auth_rate_limit_attempts') || '25');",
                  "",
                  "pm.test('Status code is 401 or 429 during probe', function () {",
                  "  pm.expect([401, 429]).to.include(pm.response.code);",
                  "});",
                  "",
                  "if (pm.response.code === 429) {",
                  "  pm.environment.set('auth_rate_limited', 'true');",
                  "  postman.setNextRequest('12. Assert Rate Limiting Triggered');",
                  "} else if (current < maxAttempts) {",
                  "  postman.setNextRequest('11. Auth Rate Limit Probe');",
                  "} else {",
                  "  pm.environment.set('auth_rate_limited', 'false');",
                  "  postman.setNextRequest('12. Assert Rate Limiting Triggered');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"rate.limit.user@example.com\",\n  \"password\": \"WrongPass123\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          }
        },
        {
          "name": "12. Assert Rate Limiting Triggered",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Rate limiting was triggered', function () {",
                  "  pm.expect(pm.environment.get('auth_rate_limited')).to.equal('true');",
                  "});",
                  "",
                  "pm.test('Probe finished within configured attempts', function () {",
                  "  const current = Number(pm.environment.get('auth_flood_counter') || '0');",
                  "  const maxAttempts = Number(pm.environment.get('auth_rate_limit_attempts') || '25');",
                  "  pm.expect(current).to.be.at.most(maxAttempts);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                ""
              ]
            }
          }
        }
      ]
    }
  ]
}
