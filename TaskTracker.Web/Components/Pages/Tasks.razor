@page "/app/projects/{ProjectId:guid}/tasks"
@attribute [Authorize]
@rendermode InteractiveServer
@using System.Globalization
@using Microsoft.AspNetCore.WebUtilities
@using TaskTracker.Web.Dtos
@using TaskTracker.Web.Dtos.Tasks
@using TaskTracker.Web.Models
@using TaskTracker.Web.Services.Tasks
@using TaskTracker.Web.Services.Projects
@using TaskTracker.Web.Services.Auth
@inject ITasksApiClient TasksApiClient
@inject IProjectsApiClient ProjectsApiClient
@inject NavigationManager NavigationManager
@inject IAuthSessionStore AuthSessionStore

<PageTitle>Task lista</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1>Feladatok</h1>
        @if (_project is not null)
        {
            <p class="text-muted">Projekt: @_project.Name</p>
        }
    </div>
    <button class="btn btn-primary" type="button" @onclick="NavigateToCreate">
        Új feladat
    </button>
</div>

@if (_isLoading)
{
    <LoadingIndicator Text="Feladatok betoltese..." />
}
else if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <FeedbackMessage Message="@_errorMessage" Type="FeedbackMessage.FeedbackType.Error" />
}
else
{
    <FeedbackMessage Message="@_successMessage" Type="FeedbackMessage.FeedbackType.Success" />

    <TaskFilters CurrentQuery="_currentQuery" OnFilterChange="HandleFilterChange" />

    @if (_tasks is null || _tasks.Items.Count == 0)
    {
        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <h2 class="h5 mb-2">@GetEmptyStateTitle()</h2>
                <p class="text-muted mb-3">@GetEmptyStateMessage()</p>

                <div class="d-flex flex-wrap gap-2">
                    @if (HasActiveFilters)
                    {
                        <button class="btn btn-outline-secondary" type="button" @onclick="ResetFilters">
                            Szűrők törlése
                        </button>
                    }

                    @if (_currentQuery.Page > 1 && _tasks is not null && _tasks.TotalPages > 1)
                    {
                        <button class="btn btn-outline-primary" type="button" @onclick="GoToFirstPage">
                            Első oldal
                        </button>
                    }

                    <button class="btn btn-primary" type="button" @onclick="NavigateToCreate">
                        Új feladat létrehozása
                    </button>
                </div>
            </div>
        </div>
    }
    else
    {
        <TaskList ProjectId="ProjectId" Tasks="_tasks.Items" DeletingTaskId="_isDeletingTaskId" OnDeleteRequested="HandleDeleteTaskAsync" />

        @if (_tasks.TotalPages > 1)
        {
            <PaginationControls CurrentPage="_currentQuery.Page" TotalPages="_tasks.TotalPages" OnPageChange="HandlePageChange" />
        }
    }
}

<ConfirmDialog
    IsOpen="@_pendingDeleteTaskId.HasValue"
    IsBusy="@_isDeletingTaskId.HasValue"
    Title="Feladat torlese"
    Message="@GetDeleteTaskMessage()"
    ConfirmText="Feladat torlese"
    BusyConfirmText="Torles..."
    OnConfirm="ConfirmDeleteTaskAsync"
    OnCancel="CancelDeleteTaskAsync" />

<div class="mt-4">
    <button class="btn btn-outline-secondary" type="button" @onclick="NavigateToProject">
        Vissza a projekthez
    </button>
</div>

@code {
    [Parameter]
    public Guid ProjectId { get; set; }

    private ProjectDetailsDto? _project;
    private PaginatedResultDto<TaskListItemDto>? _tasks;
    private GetTasksQueryDto _currentQuery = new();
    private string? _errorMessage;
    private string? _successMessage;
    private bool _isLoading = true;
    private Guid? _isDeletingTaskId;
    private Guid? _pendingDeleteTaskId;
    private string? _pendingDeleteTaskTitle;

    protected override async Task OnParametersSetAsync()
    {
        _currentQuery = ParseQueryState(NavigationManager.Uri);

        if (_project is null || _project.Id != ProjectId)
        {
            await LoadProjectAsync();
            if (_project is null)
            {
                return;
            }
        }

        await LoadTasksAsync();
    }

    private async Task LoadProjectAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            _project = await ProjectsApiClient.GetProjectByIdAsync(ProjectId);
        }
        catch (Exception ex)
        {
            if (!ApiUiFlow.TryHandleNavigation(ex, NavigationManager))
            {
                _errorMessage = ApiUiFlow.ToUserMessage(ex);
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadTasksAsync(bool resetTransientMessages = true)
    {
        _isLoading = true;
        if (resetTransientMessages)
        {
            _errorMessage = null;
            _successMessage = null;
        }

        try
        {
            _tasks = await TasksApiClient.GetTasksAsync(ProjectId, _currentQuery);
        }
        catch (Exception ex)
        {
            if (!ApiUiFlow.TryHandleNavigation(ex, NavigationManager))
            {
                _errorMessage = ApiUiFlow.ToUserMessage(ex);
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    private Task HandleFilterChange(GetTasksQueryDto query)
    {
        NavigateToQuery(query);
        return Task.CompletedTask;
    }

    private Task HandlePageChange(int page)
    {
        var query = CloneQuery(_currentQuery);
        query.Page = page;
        NavigateToQuery(query);
        return Task.CompletedTask;
    }

    private async Task HandleDeleteTaskAsync(Guid taskId)
    {
        _pendingDeleteTaskId = taskId;
        _pendingDeleteTaskTitle = _tasks?.Items.FirstOrDefault(task => task.Id == taskId)?.Title;
        await Task.CompletedTask;
    }

    private Task CancelDeleteTaskAsync()
    {
        _pendingDeleteTaskId = null;
        _pendingDeleteTaskTitle = null;
        return Task.CompletedTask;
    }

    private async Task ConfirmDeleteTaskAsync()
    {
        if (!_pendingDeleteTaskId.HasValue)
        {
            return;
        }

        var taskId = _pendingDeleteTaskId.Value;
        _isDeletingTaskId = taskId;
        _errorMessage = null;

        try
        {
            await TasksApiClient.DeleteTaskAsync(ProjectId, taskId);
            await LoadTasksAsync(resetTransientMessages: false);
            _successMessage = "Feladat sikeresen torolve.";
        }
        catch (Exception ex)
        {
            if (!ApiUiFlow.TryHandleNavigation(ex, NavigationManager))
            {
                _errorMessage = ApiUiFlow.ToUserMessage(ex);
            }
        }
        finally
        {
            _isDeletingTaskId = null;
            await CancelDeleteTaskAsync();
        }
    }

    private string GetDeleteTaskMessage()
    {
        var taskName = string.IsNullOrWhiteSpace(_pendingDeleteTaskTitle)
            ? "ezt a feladatot"
            : $"a(z) '{_pendingDeleteTaskTitle}' feladatot";

        return $"Biztosan torlod {taskName}?";
    }

    private void ResetFilters()
    {
        NavigateToQuery(new GetTasksQueryDto
        {
            Page = 1,
            Limit = _currentQuery.Limit
        });
    }

    private void GoToFirstPage()
    {
        var query = CloneQuery(_currentQuery);
        query.Page = 1;
        NavigateToQuery(query);
    }

    private void NavigateToCreate()
    {
        NavigationManager.NavigateTo($"/app/projects/{ProjectId}/tasks/create");
    }

    private void NavigateToProject()
    {
        NavigationManager.NavigateTo($"/app/projects/{ProjectId}");
    }

    private bool HasActiveFilters =>
        _currentQuery.Status.HasValue ||
        _currentQuery.Priority.HasValue ||
        _currentQuery.AssigneeId.HasValue ||
        _currentQuery.DueFrom.HasValue ||
        _currentQuery.DueTo.HasValue ||
        _currentQuery.SortBy.HasValue ||
        _currentQuery.SortOrder.HasValue;

    private string GetEmptyStateTitle()
    {
        if (HasActiveFilters)
        {
            return "Nincs találat az aktuális szűrőkkel";
        }

        if (_currentQuery.Page > 1)
        {
            return "Nincs feladat ezen az oldalon";
        }

        return "Még nincs feladat ebben a projektben";
    }

    private string GetEmptyStateMessage()
    {
        if (HasActiveFilters)
        {
            return "A szűrési és rendezési feltételek mellett nem maradt megjeleníthető feladat. Próbáld meg lazítani a szűrőket, vagy indíts új keresést.";
        }

        if (_currentQuery.Page > 1)
        {
            return "A kiválasztott oldalon már nincs több feladat. Lépj vissza az első oldalra, vagy válassz másik oldalt a lapozóval.";
        }

        return "Ebben a projektben még nincs feladat. Hozz létre egyet, és máris megjelenik itt.";
    }

    private void NavigateToQuery(GetTasksQueryDto query)
    {
        var uri = BuildTaskListUri(query);
        NavigationManager.NavigateTo(uri, forceLoad: false);
    }

    private string BuildTaskListUri(GetTasksQueryDto query)
    {
        var parameters = new Dictionary<string, string?>
        {
            ["page"] = query.Page.ToString(CultureInfo.InvariantCulture),
            ["limit"] = query.Limit.ToString(CultureInfo.InvariantCulture)
        };

        if (query.Status.HasValue)
        {
            parameters["status"] = query.Status.Value.ToString();
        }

        if (query.Priority.HasValue)
        {
            parameters["priority"] = query.Priority.Value.ToString();
        }

        if (query.AssigneeId.HasValue)
        {
            parameters["assigneeId"] = query.AssigneeId.Value.ToString();
        }

        if (query.DueFrom.HasValue)
        {
            parameters["dueFrom"] = query.DueFrom.Value.ToString("o", CultureInfo.InvariantCulture);
        }

        if (query.DueTo.HasValue)
        {
            parameters["dueTo"] = query.DueTo.Value.ToString("o", CultureInfo.InvariantCulture);
        }

        if (query.SortBy.HasValue)
        {
            parameters["sortBy"] = query.SortBy.Value.ToString();
        }

        if (query.SortOrder.HasValue)
        {
            parameters["sortOrder"] = query.SortOrder.Value.ToString();
        }

        return QueryHelpers.AddQueryString($"/app/projects/{ProjectId}/tasks", parameters);
    }

    private static GetTasksQueryDto CloneQuery(GetTasksQueryDto source)
    {
        return new GetTasksQueryDto
        {
            Status = source.Status,
            Priority = source.Priority,
            AssigneeId = source.AssigneeId,
            DueFrom = source.DueFrom,
            DueTo = source.DueTo,
            SortBy = source.SortBy,
            SortOrder = source.SortOrder,
            Page = source.Page,
            Limit = source.Limit
        };
    }

    private static GetTasksQueryDto ParseQueryState(string uri)
    {
        var uriInfo = new Uri(uri);
        var query = QueryHelpers.ParseQuery(uriInfo.Query);

        return new GetTasksQueryDto
        {
            Status = ParseEnum<TaskItemStatus>(query, "status"),
            Priority = ParseEnum<TaskItemPriority>(query, "priority"),
            AssigneeId = ParseGuid(query, "assigneeId"),
            DueFrom = ParseDateTime(query, "dueFrom"),
            DueTo = ParseDateTime(query, "dueTo"),
            SortBy = ParseEnum<TaskSortBy>(query, "sortBy"),
            SortOrder = ParseEnum<TaskSortOrder>(query, "sortOrder"),
            Page = ParseInt(query, "page", 1, 1, int.MaxValue),
            Limit = ParseInt(query, "limit", 20, 1, 100)
        };
    }

    private static TEnum? ParseEnum<TEnum>(
        IDictionary<string, Microsoft.Extensions.Primitives.StringValues> query,
        string key)
        where TEnum : struct, Enum
    {
        if (!query.TryGetValue(key, out var values))
        {
            return null;
        }

        var value = values.ToString();
        return Enum.TryParse<TEnum>(value, true, out var parsed) ? parsed : null;
    }

    private static Guid? ParseGuid(
        IDictionary<string, Microsoft.Extensions.Primitives.StringValues> query,
        string key)
    {
        if (!query.TryGetValue(key, out var values))
        {
            return null;
        }

        return Guid.TryParse(values.ToString(), out var parsed) ? parsed : null;
    }

    private static DateTime? ParseDateTime(
        IDictionary<string, Microsoft.Extensions.Primitives.StringValues> query,
        string key)
    {
        if (!query.TryGetValue(key, out var values))
        {
            return null;
        }

        var text = values.ToString();
        if (string.IsNullOrWhiteSpace(text))
        {
            return null;
        }

        if (!DateTime.TryParse(text, CultureInfo.InvariantCulture, DateTimeStyles.RoundtripKind, out var parsed))
        {
            return null;
        }

        return parsed.Kind == DateTimeKind.Unspecified
            ? DateTime.SpecifyKind(parsed, DateTimeKind.Utc)
            : parsed;
    }

    private static int ParseInt(
        IDictionary<string, Microsoft.Extensions.Primitives.StringValues> query,
        string key,
        int defaultValue,
        int minValue,
        int maxValue)
    {
        if (!query.TryGetValue(key, out var values))
        {
            return defaultValue;
        }

        if (!int.TryParse(values.ToString(), NumberStyles.Integer, CultureInfo.InvariantCulture, out var parsed))
        {
            return defaultValue;
        }

        return Math.Clamp(parsed, minValue, maxValue);
    }
}
