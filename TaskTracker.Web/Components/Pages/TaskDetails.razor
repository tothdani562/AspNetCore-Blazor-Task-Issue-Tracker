@page "/app/projects/{ProjectId:guid}/tasks/{TaskId:guid}"
@attribute [Authorize]
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using TaskTracker.Web.Dtos
@using TaskTracker.Web.Dtos.Comments
@using TaskTracker.Web.Dtos.Tasks
@using TaskTracker.Web.Models
@using TaskTracker.Web.Services.Comments
@using TaskTracker.Web.Services.Tasks
@using TaskTracker.Web.Services.Projects
@using TaskTracker.Web.Services.Auth
@inject ITasksApiClient TasksApiClient
@inject ICommentsApiClient CommentsApiClient
@inject IProjectsApiClient ProjectsApiClient
@inject NavigationManager NavigationManager
@inject IAuthSessionStore AuthSessionStore

<PageTitle>Feladat részletei</PageTitle>

@if (_isLoading)
{
    <LoadingIndicator Text="Feladat betoltese..." />
}
else if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <FeedbackMessage Message="@_errorMessage" Type="FeedbackMessage.FeedbackType.Error" />
}
else if (_task is null)
{
    <FeedbackMessage Message="A feladat nem talalhato." Type="FeedbackMessage.FeedbackType.Warning" />
}
else
{
    <FeedbackMessage Message="@_successMessage" Type="FeedbackMessage.FeedbackType.Success" />

    <h1>@_task.Title</h1>
    <p class="text-muted mb-4">Projekt: @_project?.Name</p>

    <div class="row tt-no-overflow">
        <div class="col-md-8 tt-no-overflow">
            <section class="card mb-4">
                <div class="card-body">
                    <h2 class="h5 mb-3">Leírás</h2>
                    @if (!string.IsNullOrWhiteSpace(_task.Description))
                    {
                        <p class="tt-breakword">@_task.Description</p>
                    }
                    else
                    {
                        <p class="text-muted">Nincs leírás.</p>
                    }
                </div>
            </section>

            <section class="card mb-4">
                <div class="card-body">
                    <h2 class="h5 mb-3">Szerkesztés</h2>

                    <EditForm Model="_editModel" OnValidSubmit="HandleUpdateAsync">
                        <DataAnnotationsValidator />
                        <ValidationErrors />

                        <div class="mb-3">
                            <label class="form-label" for="taskTitle">Cím</label>
                            <InputText id="taskTitle" class="form-control" @bind-Value="_editModel.Title" />
                            <ValidationMessage For="@(() => _editModel.Title)" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="taskDescription">Leírás</label>
                            <InputTextArea id="taskDescription" class="form-control tt-breakword" @bind-Value="_editModel.Description" />
                            <ValidationMessage For="@(() => _editModel.Description)" />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label" for="taskStatus">Státusz</label>
                                <InputSelect id="taskStatus" class="form-select" @bind-Value="_editModel.Status">
                                    <option value="@TaskItemStatus.TODO">Teendő</option>
                                    <option value="@TaskItemStatus.IN_PROGRESS">Folyamatban</option>
                                    <option value="@TaskItemStatus.DONE">Kész</option>
                                </InputSelect>
                                <ValidationMessage For="@(() => _editModel.Status)" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label" for="taskPriority">Prioritás</label>
                                <InputSelect id="taskPriority" class="form-select" @bind-Value="_editModel.Priority">
                                    <option value="@TaskItemPriority.LOW">Alacsony</option>
                                    <option value="@TaskItemPriority.MEDIUM">Közepes</option>
                                    <option value="@TaskItemPriority.HIGH">Magas</option>
                                </InputSelect>
                                <ValidationMessage For="@(() => _editModel.Priority)" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label" for="taskAssignee">Hozzárendelt felhasználó (GUID)</label>
                                <InputText id="taskAssignee" class="form-control" @bind-Value="_assigneeIdString" />
                                <small class="form-text text-muted">Hagyj üresen, ha senki sincs hozzárendelve</small>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label" for="taskDueDate">Határidő</label>
                                <InputDate id="taskDueDate" class="form-control" @bind-Value="_editModel.DueDate" />
                            </div>
                        </div>

                        <button class="btn btn-primary" type="submit" disabled="@_isUpdating">
                            @(_isUpdating ? "Mentés..." : "Változások mentése")
                        </button>
                    </EditForm>
                </div>
            </section>

            <section class="card mb-4">
                <div class="card-body">
                    <h2 class="h5 mb-3">Kommentek</h2>

                    <FeedbackMessage Message="@_commentsSuccessMessage" Type="FeedbackMessage.FeedbackType.Success" />
                    <FeedbackMessage Message="@_commentsErrorMessage" Type="FeedbackMessage.FeedbackType.Error" />

                    <EditForm Model="_newCommentModel" OnValidSubmit="HandleCreateCommentAsync" class="mb-4">
                        <DataAnnotationsValidator />

                        <div class="mb-2">
                            <label class="form-label" for="newCommentContent">Új komment</label>
                            <InputTextArea id="newCommentContent" class="form-control" @bind-Value="_newCommentModel.Content" rows="3" />
                            <ValidationMessage For="@(() => _newCommentModel.Content)" />
                        </div>

                        <button class="btn btn-primary" type="submit" disabled="@_isCreatingComment">
                            @(_isCreatingComment ? "Beküldés..." : "Komment beküldése")
                        </button>
                    </EditForm>

                    @if (_isLoadingComments)
                    {
                        <LoadingIndicator Text="Kommentek betoltese..." />
                    }
                    else if (_comments is null || _comments.Items.Count == 0)
                    {
                        <p class="text-muted mb-0">Ehhez a feladathoz még nincs komment.</p>
                    }
                    else
                    {
                        @foreach (var comment in _comments.Items)
                        {
                            <article class="border rounded p-3 mb-3">
                                <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                                    <div>
                                        <div class="fw-semibold">@comment.Author.FullName</div>
                                        <small class="text-muted">@comment.Author.Email</small>
                                    </div>
                                    <div class="text-end">
                                        <small class="text-muted d-block">@comment.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</small>
                                        @if (comment.UpdatedAt > comment.CreatedAt)
                                        {
                                            <small class="text-muted">Módosítva: @comment.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</small>
                                        }
                                    </div>
                                </div>

                                @if (_editingCommentId == comment.Id)
                                {
                                    <EditForm Model="_editCommentModel" OnValidSubmit="HandleUpdateCommentAsync" class="mb-2">
                                        <DataAnnotationsValidator />

                                        <div class="mb-2">
                                            <InputTextArea class="form-control" @bind-Value="_editCommentModel.Content" rows="3" />
                                            <ValidationMessage For="@(() => _editCommentModel.Content)" />
                                        </div>

                                        <div class="d-flex gap-2">
                                            <button class="btn btn-sm btn-primary" type="submit" disabled="@_isUpdatingComment">
                                                @(_isUpdatingComment ? "Mentés..." : "Mentés")
                                            </button>
                                            <button class="btn btn-sm btn-outline-secondary" type="button" @onclick="CancelEditComment">
                                                Mégse
                                            </button>
                                        </div>
                                    </EditForm>
                                }
                                else
                                {
                                    <p class="mb-2 tt-breakword">@comment.Content</p>
                                }

                                @if (CanManageComment(comment) && _editingCommentId != comment.Id)
                                {
                                    <div class="d-flex gap-2">
                                        <button class="btn btn-sm btn-outline-primary"
                                                type="button"
                                                disabled="@(_isUpdatingComment || _deletingCommentId.HasValue)"
                                                @onclick="() => StartEditComment(comment)">
                                            Szerkesztés
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger"
                                                type="button"
                                                disabled="@(_isUpdatingComment || _deletingCommentId == comment.Id)"
                                                @onclick="() => OpenDeleteCommentDialog(comment.Id)">
                                            @(_deletingCommentId == comment.Id
                                                ? "Törlés..."
                                                : "Törlés")
                                        </button>
                                    </div>
                                }
                            </article>
                        }

                        @if (_comments.TotalPages > 1)
                        {
                            <PaginationControls CurrentPage="_commentQuery.Page" TotalPages="_comments.TotalPages" OnPageChange="HandleCommentPageChange" />
                        }
                    }
                </div>
            </section>
        </div>

        <div class="col-md-4 tt-no-overflow">
            <section class="card">
                <div class="card-body">
                    <h2 class="h5 mb-3">Adatok</h2>

                    <div class="mb-3">
                        <small class="text-muted d-block">Státusz</small>
                        <StatusBadge Status="_task.Status" />
                    </div>

                    <div class="mb-3">
                        <small class="text-muted d-block">Prioritás</small>
                        <PriorityBadge Priority="_task.Priority" />
                    </div>

                    <div class="mb-3">
                        <small class="text-muted d-block">Hozzárendelt</small>
                        @if (_task.AssignedUser is not null)
                        {
                            <p class="mb-0">@_task.AssignedUser.FullName</p>
                            <small class="text-muted">@_task.AssignedUser.Email</small>
                        }
                        else
                        {
                            <p class="text-muted mb-0">Nincs hozzárendelve</p>
                        }
                    </div>

                    <div class="mb-3">
                        <small class="text-muted d-block">Határidő</small>
                        @if (_task.DueDate.HasValue)
                        {
                            <p class="mb-0">@_task.DueDate.Value.ToLocalTime().ToString("yyyy-MM-dd")</p>
                        }
                        else
                        {
                            <p class="text-muted mb-0">--</p>
                        }
                    </div>

                    <hr />

                    <div class="mb-3">
                        <small class="text-muted d-block">Létrehozva</small>
                        <small>@_task.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</small>
                    </div>

                    <div class="mb-3">
                        <small class="text-muted d-block">Utolsó módosítás</small>
                        <small>@_task.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</small>
                    </div>
                </div>
            </section>
        </div>
    </div>

    <div class="mt-4 d-flex gap-2">
        <a href="@($"/app/projects/{ProjectId}/tasks")" class="btn btn-outline-secondary">
            Vissza a listához
        </a>
        <button class="btn btn-outline-danger" type="button"
                disabled="@_isDeleting" @onclick="HandleDeleteTaskAsync">
            Feladat torlese
        </button>
    </div>
}

<ConfirmDialog
    IsOpen="@_isTaskDeleteDialogOpen"
    IsBusy="@_isDeleting"
    Title="Feladat torlese"
    Message="A feladat torlese vegleges. Biztosan folytatod?"
    ConfirmText="Feladat torlese"
    BusyConfirmText="Torles..."
    OnConfirm="ConfirmDeleteTaskAsync"
    OnCancel="CancelDeleteTaskAsync" />

<ConfirmDialog
    IsOpen="@_pendingDeleteCommentId.HasValue"
    IsBusy="@_deletingCommentId.HasValue"
    Title="Komment torlese"
    Message="Biztosan torlod ezt a kommentet?"
    ConfirmText="Komment torlese"
    BusyConfirmText="Torles..."
    OnConfirm="ConfirmDeleteCommentAsync"
    OnCancel="CancelDeleteCommentAsync" />

@code {
    [Parameter]
    public Guid ProjectId { get; set; }

    [Parameter]
    public Guid TaskId { get; set; }

    private TaskDetailsDto? _task;
    private ProjectDetailsDto? _project;
    private readonly EditTaskModel _editModel = new();
    private readonly CreateCommentModel _newCommentModel = new();
    private readonly EditCommentModel _editCommentModel = new();
    private string? _assigneeIdString;
    private string? _errorMessage;
    private string? _successMessage;
    private PaginatedResultDto<CommentListItemDto>? _comments;
    private readonly GetCommentsQueryDto _commentQuery = new() { Page = 1, Limit = 5 };
    private string? _commentsErrorMessage;
    private string? _commentsSuccessMessage;
    private bool _isLoading = true;
    private bool _isUpdating;
    private bool _isDeleting;
    private bool _isTaskDeleteDialogOpen;
    private bool _isLoadingComments;
    private bool _isCreatingComment;
    private Guid? _editingCommentId;
    private bool _isUpdatingComment;
    private Guid? _pendingDeleteCommentId;
    private Guid? _deletingCommentId;

    protected override async Task OnParametersSetAsync()
    {
        await LoadProjectAsync();
        await LoadTaskAsync();

        if (_task is not null)
        {
            await LoadCommentsAsync();
        }
    }

    private async Task LoadProjectAsync()
    {
        try
        {
            _project = await ProjectsApiClient.GetProjectByIdAsync(ProjectId);
        }
        catch (Exception ex)
        {
            if (!ApiUiFlow.TryHandleNavigation(ex, NavigationManager))
            {
                _errorMessage = ApiUiFlow.ToUserMessage(ex);
            }
        }
    }

    private async Task LoadTaskAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        _successMessage = null;

        try
        {
            _task = await TasksApiClient.GetTaskByIdAsync(ProjectId, TaskId);
            InitializeEditModel();
        }
        catch (Exception ex)
        {
            if (!ApiUiFlow.TryHandleNavigation(ex, NavigationManager))
            {
                _errorMessage = ApiUiFlow.ToUserMessage(ex);
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task LoadCommentsAsync(bool resetTransientMessages = true)
    {
        _isLoadingComments = true;

        if (resetTransientMessages)
        {
            _commentsErrorMessage = null;
            _commentsSuccessMessage = null;
        }

        try
        {
            _comments = await CommentsApiClient.GetCommentsAsync(TaskId, _commentQuery);
        }
        catch (Exception ex)
        {
            if (!ApiUiFlow.TryHandleNavigation(ex, NavigationManager))
            {
                _commentsErrorMessage = ApiUiFlow.ToUserMessage(ex);
            }
        }
        finally
        {
            _isLoadingComments = false;
        }
    }

    private void InitializeEditModel()
    {
        if (_task is null) return;

        _editModel.Title = _task.Title;
        _editModel.Description = _task.Description ?? string.Empty;
        _editModel.Status = _task.Status;
        _editModel.Priority = _task.Priority;
        _editModel.DueDate = _task.DueDate;
        _assigneeIdString = _task.AssignedUserId?.ToString() ?? string.Empty;
    }

    private async Task HandleUpdateAsync()
    {
        _isUpdating = true;
        _successMessage = null;
        _errorMessage = null;

        try
        {
            var request = new UpdateTaskRequestDto
            {
                Title = _editModel.Title,
                Description = _editModel.Description,
                Status = _editModel.Status,
                Priority = _editModel.Priority,
                DueDate = _editModel.DueDate,
                AssignedUserId = string.IsNullOrEmpty(_assigneeIdString)
                    ? null
                    : (Guid.TryParse(_assigneeIdString, out var guid) ? guid : null)
            };

            _task = await TasksApiClient.UpdateTaskAsync(ProjectId, TaskId, request);
            _successMessage = "Feladat sikeresen frissítve.";
            InitializeEditModel();
        }
        catch (Exception ex)
        {
            if (!ApiUiFlow.TryHandleNavigation(ex, NavigationManager))
            {
                _errorMessage = ApiUiFlow.ToUserMessage(ex);
            }
        }
        finally
        {
            _isUpdating = false;
        }
    }

    private Task HandleDeleteTaskAsync()
    {
        _isTaskDeleteDialogOpen = true;
        return Task.CompletedTask;
    }

    private Task CancelDeleteTaskAsync()
    {
        _isTaskDeleteDialogOpen = false;
        return Task.CompletedTask;
    }

    private async Task ConfirmDeleteTaskAsync()
    {
        _isDeleting = true;
        _successMessage = null;
        _errorMessage = null;

        try
        {
            await TasksApiClient.DeleteTaskAsync(ProjectId, TaskId);
            NavigationManager.NavigateTo($"/app/projects/{ProjectId}/tasks");
        }
        catch (Exception ex)
        {
            if (!ApiUiFlow.TryHandleNavigation(ex, NavigationManager))
            {
                _errorMessage = ApiUiFlow.ToUserMessage(ex);
            }
        }
        finally
        {
            _isDeleting = false;
            _isTaskDeleteDialogOpen = false;
        }
    }

    private async Task HandleCreateCommentAsync()
    {
        _isCreatingComment = true;
        _commentsErrorMessage = null;
        _commentsSuccessMessage = null;

        try
        {
            await CommentsApiClient.CreateCommentAsync(TaskId, new CreateCommentRequestDto
            {
                Content = _newCommentModel.Content
            });

            _newCommentModel.Content = string.Empty;
            _commentQuery.Page = 1;
            await LoadCommentsAsync(resetTransientMessages: false);
            _commentsSuccessMessage = "Komment sikeresen létrehozva.";
        }
        catch (Exception ex)
        {
            if (!ApiUiFlow.TryHandleNavigation(ex, NavigationManager))
            {
                _commentsErrorMessage = ApiUiFlow.ToUserMessage(ex);
            }
        }
        finally
        {
            _isCreatingComment = false;
        }
    }

    private void StartEditComment(CommentListItemDto comment)
    {
        _editingCommentId = comment.Id;
        _editCommentModel.Content = comment.Content;
        _commentsErrorMessage = null;
        _commentsSuccessMessage = null;
        _pendingDeleteCommentId = null;
    }

    private void CancelEditComment()
    {
        _editingCommentId = null;
        _editCommentModel.Content = string.Empty;
    }

    private async Task HandleUpdateCommentAsync()
    {
        if (!_editingCommentId.HasValue)
        {
            return;
        }

        _isUpdatingComment = true;
        _commentsErrorMessage = null;
        _commentsSuccessMessage = null;

        try
        {
            await CommentsApiClient.UpdateCommentAsync(TaskId, _editingCommentId.Value, new UpdateCommentRequestDto
            {
                Content = _editCommentModel.Content
            });

            await LoadCommentsAsync(resetTransientMessages: false);
            _commentsSuccessMessage = "Komment sikeresen frissítve.";
            CancelEditComment();
        }
        catch (Exception ex)
        {
            if (!ApiUiFlow.TryHandleNavigation(ex, NavigationManager))
            {
                _commentsErrorMessage = ApiUiFlow.ToUserMessage(ex);
            }
        }
        finally
        {
            _isUpdatingComment = false;
        }
    }

    private Task OpenDeleteCommentDialog(Guid commentId)
    {
        _pendingDeleteCommentId = commentId;
        return Task.CompletedTask;
    }

    private Task CancelDeleteCommentAsync()
    {
        _pendingDeleteCommentId = null;
        return Task.CompletedTask;
    }

    private async Task ConfirmDeleteCommentAsync()
    {
        if (!_pendingDeleteCommentId.HasValue)
        {
            return;
        }

        var commentId = _pendingDeleteCommentId.Value;
        _deletingCommentId = commentId;
        _commentsErrorMessage = null;
        _commentsSuccessMessage = null;

        try
        {
            if (_comments is not null && _comments.Items.Count == 1 && _commentQuery.Page > 1)
            {
                _commentQuery.Page--;
            }

            await CommentsApiClient.DeleteCommentAsync(TaskId, commentId);
            await LoadCommentsAsync(resetTransientMessages: false);
            _commentsSuccessMessage = "Komment sikeresen törölve.";
        }
        catch (Exception ex)
        {
            if (!ApiUiFlow.TryHandleNavigation(ex, NavigationManager))
            {
                _commentsErrorMessage = ApiUiFlow.ToUserMessage(ex);
            }
        }
        finally
        {
            _deletingCommentId = null;
            _pendingDeleteCommentId = null;
        }
    }

    private async Task HandleCommentPageChange(int page)
    {
        if (page < 1 || page == _commentQuery.Page)
        {
            return;
        }

        _commentQuery.Page = page;
        await LoadCommentsAsync();
    }

    private bool CanManageComment(CommentListItemDto comment)
    {
        var currentUserId = AuthSessionStore.CurrentUser?.Id;
        if (!currentUserId.HasValue)
        {
            return false;
        }

        return comment.AuthorId == currentUserId.Value || _project?.Owner.Id == currentUserId.Value;
    }

    private class EditTaskModel
    {
        [Required]
        [MinLength(3)]
        [MaxLength(200)]
        public string Title { get; set; } = string.Empty;

        [MaxLength(2000)]
        public string? Description { get; set; }

        [Required]
        public TaskItemStatus Status { get; set; } = TaskItemStatus.TODO;

        [Required]
        public TaskItemPriority Priority { get; set; } = TaskItemPriority.MEDIUM;

        public DateTime? DueDate { get; set; }
    }

    private class CreateCommentModel
    {
        [Required]
        [MinLength(1)]
        [MaxLength(2000)]
        public string Content { get; set; } = string.Empty;
    }

    private class EditCommentModel
    {
        [Required]
        [MinLength(1)]
        [MaxLength(2000)]
        public string Content { get; set; } = string.Empty;
    }
}
