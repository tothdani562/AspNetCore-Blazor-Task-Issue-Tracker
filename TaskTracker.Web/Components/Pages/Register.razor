@page "/register"
@rendermode InteractiveServer
@inject AuthFacade AuthFacade
@inject NavigationManager NavigationManager

<PageTitle>Register</PageTitle>

<h1>Regisztracio</h1>

@if (!string.IsNullOrWhiteSpace(_errorMessage))
{
    <div class="alert alert-danger" role="alert">@_errorMessage</div>
}

<EditForm Model="_model" OnValidSubmit="HandleSubmitAsync">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label class="form-label" for="fullName">Teljes nev</label>
        <InputText id="fullName" class="form-control" @bind-Value="_model.FullName" />
        <ValidationMessage For="@(() => _model.FullName)" />
    </div>

    <div class="mb-3">
        <label class="form-label" for="email">Email</label>
        <InputText id="email" class="form-control" @bind-Value="_model.Email" />
        <ValidationMessage For="@(() => _model.Email)" />
    </div>

    <div class="mb-3">
        <label class="form-label" for="password">Jelszo</label>
        <InputText id="password" type="password" class="form-control" @bind-Value="_model.Password" />
        <ValidationMessage For="@(() => _model.Password)" />
    </div>

    <button class="btn btn-primary" type="submit" disabled="@_isSubmitting">
        @(_isSubmitting ? "Regisztracio..." : "Regisztracio")
    </button>
</EditForm>

<p class="mt-3">
    Van mar fiokod? <a href="/login">Bejelentkezes</a>
</p>

@code {
    private readonly RegisterRequestDto _model = new();
    private string? _errorMessage;
    private bool _isSubmitting;

    private async Task HandleSubmitAsync()
    {
        _isSubmitting = true;
        _errorMessage = null;

        try
        {
            await AuthFacade.RegisterAsync(_model);
            NavigationManager.NavigateTo("/home", forceLoad: false);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}