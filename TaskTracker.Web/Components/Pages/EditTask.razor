@page "/app/projects/{ProjectId:guid}/tasks/{TaskId:guid}/edit"
@attribute [Authorize]
@rendermode InteractiveServer
@using System.ComponentModel.DataAnnotations
@using TaskTracker.Web.Dtos
@using TaskTracker.Web.Dtos.Tasks
@using TaskTracker.Web.Models
@using TaskTracker.Web.Services.Tasks
@using TaskTracker.Web.Services.Projects
@inject ITasksApiClient TasksApiClient
@inject IProjectsApiClient ProjectsApiClient
@inject NavigationManager NavigationManager

<PageTitle>Feladat szerkesztése</PageTitle>

<div class="row">
    <div class="col-md-8">
        @if (_isLoading)
        {
            <LoadingIndicator Text="Feladat betoltese..." />
        }
        else if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <FeedbackMessage Message="@_errorMessage" Type="FeedbackMessage.FeedbackType.Error" />
        }
        else if (_task is null)
        {
            <FeedbackMessage Message="A feladat nem talalhato." Type="FeedbackMessage.FeedbackType.Warning" />
        }
        else
        {
            <h1>@_task.Title szerkesztése</h1>
            @if (_project is not null)
            {
                <p class="text-muted mb-4">Projekt: @_project.Name</p>
            }

            <div class="card tt-form">
                <div class="card-body">
                    <EditForm Model="_editModel" OnValidSubmit="HandleUpdateAsync">
                        <DataAnnotationsValidator />
                        <ValidationErrors />

                        <div class="mb-3">
                            <label class="form-label" for="title">Cím</label>
                            <InputText id="title" class="form-control" @bind-Value="_editModel.Title" />
                            <ValidationMessage For="@(() => _editModel.Title)" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label" for="description">Leírás</label>
                            <InputTextArea id="description" class="form-control" @bind-Value="_editModel.Description" />
                            <ValidationMessage For="@(() => _editModel.Description)" />
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label" for="status">Státusz</label>
                                <InputSelect id="status" class="form-select" @bind-Value="_editModel.Status">
                                    <option value="@TaskItemStatus.TODO">Teendő</option>
                                    <option value="@TaskItemStatus.IN_PROGRESS">Folyamatban</option>
                                    <option value="@TaskItemStatus.DONE">Kész</option>
                                </InputSelect>
                                <ValidationMessage For="@(() => _editModel.Status)" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label" for="priority">Prioritás</label>
                                <InputSelect id="priority" class="form-select" @bind-Value="_editModel.Priority">
                                    <option value="@TaskItemPriority.LOW">Alacsony</option>
                                    <option value="@TaskItemPriority.MEDIUM">Közepes</option>
                                    <option value="@TaskItemPriority.HIGH">Magas</option>
                                </InputSelect>
                                <ValidationMessage For="@(() => _editModel.Priority)" />
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label" for="assignee">Hozzárendelt felhasználó (GUID)</label>
                                <InputText id="assignee" class="form-control" @bind-Value="_assigneeIdString" />
                                <small class="form-text text-muted">Hagyj üresen, ha senki sincs hozzárendelve</small>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label" for="dueDate">Határidő</label>
                                <InputDate id="dueDate" class="form-control" @bind-Value="_editModel.DueDate" />
                            </div>
                        </div>

                        <div class="d-flex gap-2">
                            <button class="btn btn-primary" type="submit" disabled="@_isUpdating">
                                @(_isUpdating ? "Mentés..." : "Változások mentése")
                            </button>
                            <a href="@($"/app/projects/{ProjectId}/tasks/{TaskId}")" class="btn btn-outline-secondary">
                                Mégse
                            </a>
                        </div>
                    </EditForm>
                </div>
            </div>
        }
    </div>
</div>

@code {
    [Parameter]
    public Guid ProjectId { get; set; }

    [Parameter]
    public Guid TaskId { get; set; }

    private TaskDetailsDto? _task;
    private ProjectDetailsDto? _project;
    private readonly EditTaskModel _editModel = new();
    private string? _assigneeIdString;
    private string? _errorMessage;
    private bool _isLoading = true;
    private bool _isUpdating;

    protected override async Task OnParametersSetAsync()
    {
        await LoadProjectAsync();
        await LoadTaskAsync();
    }

    private async Task LoadProjectAsync()
    {
        try
        {
            _project = await ProjectsApiClient.GetProjectByIdAsync(ProjectId);
        }
        catch (Exception ex)
        {
            if (!ApiUiFlow.TryHandleNavigation(ex, NavigationManager))
            {
                _errorMessage = ApiUiFlow.ToUserMessage(ex);
            }
        }
    }

    private async Task LoadTaskAsync()
    {
        _isLoading = true;
        _errorMessage = null;

        try
        {
            _task = await TasksApiClient.GetTaskByIdAsync(ProjectId, TaskId);
            InitializeEditModel();
        }
        catch (Exception ex)
        {
            if (!ApiUiFlow.TryHandleNavigation(ex, NavigationManager))
            {
                _errorMessage = ApiUiFlow.ToUserMessage(ex);
            }
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void InitializeEditModel()
    {
        if (_task is null) return;

        _editModel.Title = _task.Title;
        _editModel.Description = _task.Description ?? string.Empty;
        _editModel.Status = _task.Status;
        _editModel.Priority = _task.Priority;
        _editModel.DueDate = _task.DueDate;
        _assigneeIdString = _task.AssignedUserId?.ToString() ?? string.Empty;
    }

    private async Task HandleUpdateAsync()
    {
        _isUpdating = true;
        _errorMessage = null;

        try
        {
            var request = new UpdateTaskRequestDto
            {
                Title = _editModel.Title,
                Description = _editModel.Description,
                Status = _editModel.Status,
                Priority = _editModel.Priority,
                DueDate = _editModel.DueDate,
                AssignedUserId = string.IsNullOrEmpty(_assigneeIdString)
                    ? null
                    : (Guid.TryParse(_assigneeIdString, out var guid) ? guid : null)
            };

            await TasksApiClient.UpdateTaskAsync(ProjectId, TaskId, request);
            NavigationManager.NavigateTo($"/app/projects/{ProjectId}/tasks/{TaskId}");
        }
        catch (Exception ex)
        {
            if (!ApiUiFlow.TryHandleNavigation(ex, NavigationManager))
            {
                _errorMessage = ApiUiFlow.ToUserMessage(ex);
            }
        }
        finally
        {
            _isUpdating = false;
        }
    }

    private class EditTaskModel
    {
        [Required]
        [MinLength(3)]
        [MaxLength(200)]
        public string Title { get; set; } = string.Empty;

        [MaxLength(2000)]
        public string? Description { get; set; }

        [Required]
        public TaskItemStatus Status { get; set; } = TaskItemStatus.TODO;

        [Required]
        public TaskItemPriority Priority { get; set; } = TaskItemPriority.MEDIUM;

        public DateTime? DueDate { get; set; }
    }
}
