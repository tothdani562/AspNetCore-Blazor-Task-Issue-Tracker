<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="home">TaskTracker</a>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="home" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3 nav-user-info">
                    <span class="nav-link">@AuthSessionStore.CurrentUser?.FullName</span>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="app/projects">
                        <span class="bi bi-kanban-nav-menu" aria-hidden="true"></span> Projects
                    </NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="logout">Logout</NavLink>
                </div>
            </Authorized>

            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="login">Login</NavLink>
                </div>

                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="register">Register</NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    [Inject]
    private IAuthSessionStore AuthSessionStore { get; set; } = default!;
}

