@inherits LayoutComponentBase
@inject IAuthSessionStore AuthSessionStore

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <div class="top-row-brand">
                <span class="top-row-app">Task Tracker</span>
                <small class="top-row-subtitle">Blazor + ASP.NET Core</small>
            </div>
            <AuthorizeView>
                <Authorized>
                    <div class="top-row-user">
                        <span>@AuthSessionStore.CurrentUser?.FullName</span>
                    </div>
                </Authorized>
            </AuthorizeView>
        </div>

        <article class="content px-4 py-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
