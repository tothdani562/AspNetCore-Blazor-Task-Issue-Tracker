{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=tasktracker_db;Username=tasktracker;Password=tasktracker_dev_password;"
  },
  "Jwt": {
    "Issuer": "TaskTracker.Web",
    "Audience": "TaskTracker.Client",
    "SigningKey": "THIS_IS_A_DEVELOPMENT_ONLY_SIGNING_KEY_CHANGE_IN_PRODUCTION_2026",
